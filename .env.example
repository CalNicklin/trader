# Required for AI evals and agent (local dev)
ANTHROPIC_API_KEY=sk-ant-...

# Required by config (use placeholders for evals-only runs)
RESEND_API_KEY=re_placeholder
ALERT_EMAIL_TO=you@example.com

# Database (defaults to ./data/trader.db)
# Run `bun run db:pull` to copy production DB for eval task seeding
# DB_PATH=./data/trader.db

# Optional: skip budget check when running evals locally
# EVAL_SKIP_BUDGET=true

# Daily API budget (USD). 0 = no limit. Set e.g. 3 to cap Sonnet escalation spend.
# DAILY_API_BUDGET_USD=0
